{
  "info": {
    "name": "Bookstore API",
    "description": "Postman/newman suite for the Bookstore API. Run with: npm run postman",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "token", "value": "" }],
  "item": [
    {
      "name": "Reset fixtures",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/reset",
          "host": ["{{baseUrl}}"],
          "path": ["reset"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('reset ok', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - valid credentials",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth",
          "host": ["{{baseUrl}}"],
          "path": ["auth"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returns a token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('token', body.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get books",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const books = pm.response.json();",
              "pm.test('two seeded books', () => pm.expect(books).to.have.lengthOf(2));",
              "pm.test('each book has the expected shape', () => {",
              "  books.forEach((b) => {",
              "    pm.expect(b).to.have.all.keys('id', 'title', 'author', 'price');",
              "    pm.expect(b.price).to.be.a('number');",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create book - with token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Domain-Driven Design\",\n  \"author\": \"Eric Evans\",\n  \"price\": 49.99\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "pm.test('echoes the created title', () => pm.expect(pm.response.json().title).to.eql('Domain-Driven Design'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Create book - without token is rejected",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"No Auth\",\n  \"author\": \"Nobody\",\n  \"price\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    }
  ]
}
